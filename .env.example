# Copy this file to .env.local (gitignored) and fill in real values from
# your Supabase project settings (Project Settings -> API).
# Apply supabase/migrations/0001_quiz_results.sql to that project first.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses Row Level Security entirely - required for the
# /analytics dashboard to read participant data (including email), which
# the anon key structurally cannot see. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Server-only. Shared passcode that gates /analytics. Also doubles as the
# signing secret for the analytics session cookie, so rotating this value
# immediately logs out every existing session.
ANALYTICS_PASSCODE=choose-a-long-random-passcode
